{
  "name": "farm-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -f .next/dev/lock && next dev --webpack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:seed": "DATABASE_URL=\"file:./prisma/dev.db\" tsx prisma/seed.ts",
    "db:migrate:prod": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script 2>/dev/null | turso db shell delta-livestock",
    "db:seed:prod": "dotenv -e .env.production -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.34.3",
    "idb": "^8.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
