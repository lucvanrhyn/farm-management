{
  "name": "farm-management",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "rm -f .next/dev/lock && next dev --webpack --port 3001",
    "prebuild": "tsx scripts/create-template.ts",
    "build": "prisma generate && eslint && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:seed": "DATABASE_URL=\"file:./prisma/dev.db\" tsx prisma/seed.ts",
    "db:migrate:prod": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script 2>/dev/null | turso db shell trio-b-boerdery",
    "db:migrate": "dotenv-cli -e .env.local -- tsx scripts/migrate.ts",
    "db:migrate:tenants:prod": "dotenv-cli -e .env.production -- tsx scripts/migrate.ts",
    "db:seed:prod": "dotenv -e .env.production -- tsx prisma/seed.ts",
    "db:seed:meta": "dotenv-cli -e .env.local -- tsx scripts/seed-meta-db.ts",
    "db:migrate:meta": "dotenv-cli -e .env.local -- tsx scripts/migrate-meta-db-pricing.ts",
    "db:migrate-meta-branch-clones": "dotenv-cli -e .env.local -- tsx scripts/migrate-meta-branch-clones.ts",
    "db:migrate:meta:vitals": "dotenv-cli -e .env.local -- tsx scripts/migrate-meta-vitals-events.ts",
    "perf:analyze": "ANALYZE=true pnpm build",
    "perf:lhci": "lhci autorun --config=lighthouserc.json",
    "perf:audit": "pnpm build && pnpm perf:lhci",
    "db:resync-passwords": "dotenv-cli -e .env.local -- tsx scripts/resync-passwords.ts",
    "db:verify-auth": "dotenv-cli -e .env.local -- tsx scripts/verify-auth.ts",
    "db:gen-schema": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "diff-farm-cutover": "tsx scripts/diff-farm-cutover.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@libsql/client": "^0.8.1",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@prisma/adapter-libsql": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@serwist/next": "^9.5.6",
    "@turf/area": "^7.3.4",
    "@turf/centroid": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/nearest-point": "^7.3.5",
    "@tursodatabase/api": "^1.9.2",
    "@vercel/blob": "^2.3.2",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.34.3",
    "idb": "^8.0.3",
    "inngest": "^4.2.4",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "mapbox-gl": "^3.20.0",
    "next": "16.2.4",
    "next-auth": "^4.24.13",
    "openai": "^6.34.0",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.0",
    "regression": "^2.0.1",
    "resend": "^6.10.0",
    "rrule": "^2.8.1",
    "serwist": "^9.5.6",
    "web-push": "^3.6.7",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@inngest/test": "^1.0.0",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox-gl": "^3.5.0",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2",
      "brace-expansion": "^2.0.3",
      "picomatch": ">=4.0.4",
      "dompurify": ">=3.4.0",
      "protocol-buffers-schema": ">=3.6.1",
      "vite": ">=8.0.5"
    }
  },
  "browserslist": [
    "chrome >= 90",
    "edge >= 90",
    "firefox >= 90",
    "safari >= 14",
    "ios_saf >= 14",
    "not dead",
    "not ie > 0",
    "not op_mini all"
  ]
}
