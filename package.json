{
  "name": "farm-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -f .next/dev/lock && next dev --webpack --port 3001",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:seed": "DATABASE_URL=\"file:./prisma/dev.db\" tsx prisma/seed.ts",
    "db:migrate:prod": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script 2>/dev/null | turso db shell delta-livestock",
    "db:seed:prod": "dotenv -e .env.production -- tsx prisma/seed.ts",
    "db:seed:meta": "dotenv-cli -e .env.local -- tsx scripts/seed-meta-db.ts",
    "db:migrate:meta": "dotenv-cli -e .env.local -- tsx scripts/migrate-meta-db-pricing.ts",
    "db:resync-passwords": "dotenv-cli -e .env.local -- tsx scripts/resync-passwords.ts",
    "db:verify-auth": "dotenv-cli -e .env.local -- tsx scripts/verify-auth.ts",
    "db:gen-schema": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@libsql/client": "^0.8.1",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@prisma/adapter-libsql": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@serwist/next": "^9.5.6",
    "@turf/area": "^7.3.4",
    "@tursodatabase/api": "^1.9.2",
    "@vercel/blob": "^2.3.2",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.34.3",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "mapbox-gl": "^3.20.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.0",
    "resend": "^6.10.0",
    "serwist": "^9.5.6",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/mapbox-gl": "^3.5.0",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
