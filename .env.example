# ── Local development (SQLite) ─────────────────────────────────────
DATABASE_URL=file:./prisma/dev.db

# ── Production database (Turso / libSQL) ───────────────────────────
# Get these from: turso db show <db-name> --url && turso db tokens create <db-name>
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# ── NextAuth ────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-char-secret-here
# Local dev: http://localhost:3000 | Production: your Vercel URL
NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# ── Meta DB (multi-tenant auth routing) ────────────────────────────
META_TURSO_URL=libsql://farmtrack-meta-your-org.turso.io
META_TURSO_AUTH_TOKEN=your-meta-auth-token

# ── Turso Platform API (automated provisioning) ───────────────────
# Get token from: turso auth api-tokens mint farmtrack-provisioner
TURSO_API_TOKEN=your-platform-api-token
TURSO_ORG=your-turso-org

# ── Email (Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=FarmTrack <noreply@farmtrack.app>

# ── Google Sheets (not yet implemented) ────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Anthropic AI (Import Wizard) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Platform Admin — comma-separated email list for consulting CRM access
PLATFORM_ADMIN_EMAILS=lucvanrhyn@icloud.com
