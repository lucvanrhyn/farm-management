# =============================================================================
# FarmTrack environment variables
#
# KEY:
#   [P]  Required in BOTH Preview AND Production on Vercel. Missing these on a
#        Preview deploy breaks login / onboarding / payments silently.
#        (See Vercel → Settings → Environment Variables → "Preview" checkbox.)
#   [S]  Server-only — never exposed to the browser. Safe in Vercel secret env.
#   [C]  Browser-safe (prefixed NEXT_PUBLIC_*). Inlined into the client bundle.
#   [D]  Dev-only / optional — skip in Vercel if the feature isn't used.
#
# 2026-04-18 learning: a "login works locally but fails on preview" bug was
# caused by Preview-environment drift on the [P] rows below. Keep Preview and
# Production in sync unless a key is explicitly scoped to one.
# =============================================================================

# ── Local development (SQLite) [D, S] ──────────────────────────────
DATABASE_URL=file:./prisma/dev.db

# ── Production database (Turso / libSQL) [P, S] ────────────────────
# Get these from: turso db show <db-name> --url && turso db tokens create <db-name>
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# ── NextAuth [P, S] ────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-char-secret-here
# Local dev: http://localhost:3000 | Production: your Vercel URL
NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# ── Meta DB (multi-tenant auth routing) [P, S] ─────────────────────
# If these are missing on Preview, every login fails with SERVER_MISCONFIGURED
# (post-fix diagnostic error). Historically they failed silently as "wrong
# password". Always copy Production values into Preview on Vercel.
META_TURSO_URL=libsql://farmtrack-meta-your-org.turso.io
META_TURSO_AUTH_TOKEN=your-meta-auth-token

# ── Turso Platform API (automated provisioning) [P, S] ────────────
# Required on Preview if you want `/api/auth/register` to actually provision
# a new tenant DB. Without it, registration returns a 500.
# Get token from: turso auth api-tokens mint farmtrack-provisioner
TURSO_API_TOKEN=your-platform-api-token
TURSO_ORG=your-turso-org

# ── Email (Resend) [P, S] ──────────────────────────────────────────
# Required for register verification emails AND /api/auth/resend-verification.
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=FarmTrack <noreply@farmtrack.app>

# ── OpenAI (AI Import Wizard) [P, S] ───────────────────────────────
# Used by lib/onboarding/adaptive-import.ts for column-mapping proposals.
# Model: gpt-4o-mini. Prompt caching is automatic (no config needed).
# Without it, onboarding step 2 fails with 502 → TemplateFallback.
OPENAI_API_KEY=sk-your-openai-key-here

# Platform Admin [P, S] — comma-separated email list for consulting CRM access
PLATFORM_ADMIN_EMAILS=admin@yourfarm.com

# ── PayFast (Payment Gateway) [P, S] ──────────────────────────────
# Required on Preview for the tier-gating middleware in proxy.ts.
# When PAYFAST_MERCHANT_ID is empty, proxy.ts skips the gate (safe fallback),
# but any real payment flow will 500 without these.
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# ── Web Push Notifications (VAPID) [P, S + one C] ─────────────────
VAPID_SUBJECT=mailto:admin@yourfarm.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# [C] This one is bundled into the client JS and must be set at build time.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Vercel Blob (Photo Storage) [P, S] ─────────────────────────────
# Without this, /api/photos/upload returns 500 on every observation with a photo.
BLOB_READ_WRITE_TOKEN=

# ── Cron Authentication [P, S] ─────────────────────────────────────
CRON_SECRET=

# ── Inngest — durable function platform (Phase J) [P, S] ──────────
# Powers the per-tenant notification engine fan-out (see research-phase-j-notifications.md §A).
# Without these, /api/inngest rejects event writes and the daily alert fan-out is a no-op.
# Get from: https://app.inngest.com → Apps → farmtrack → Keys (event key + signing key).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Mapbox (Farm Map Rendering) [P, C] ─────────────────────────────
# Bundled into the client JS at build time. Missing = blank map + console 401s.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ-your-mapbox-public-token

# ── Perf cache feature flag [D, S] ────────────────────────────────
# Controls which tenant slugs use unstable_cache (Next.js data cache) for
# dashboard + layout queries.  Missing / empty = off for all tenants (safe).
#
# Values:
#   unset or ""           → caching OFF for all tenants (default / rollback)
#   FARM_CACHE_ENABLED_SLUGS=*            → caching ON for ALL tenants
#   FARM_CACHE_ENABLED_SLUGS=trio-b,basson → allowlist (staged rollout)
#
# Recommended staged rollout: set one slug → soak 1 h → add next → soak 24 h
# → switch to "*" → delete this variable + lib/flags.ts after one clean week.
FARM_CACHE_ENABLED_SLUGS=

# ── Phase K map moat layers [D, S/C] ───────────────────────────────
# EskomSePush (https://eskomsepush.gospelapps.co.za/) drives load-shedding timing
# on the admin map banner + water-point task scheduling. Missing → the Eskom
# layer gracefully renders `{ _stale: true, _error: "NO_TOKEN" }` and the banner
# hides itself. Optional on Preview/Prod until the feature is wired live.
ESKOMSEPUSH_TOKEN=
# Raster tile template URL for MTN/Vodacom/Rain coverage tiles on the admin map.
# When unset, the MtnCoverageLayer renders a visible checkerboard placeholder
# (so dev can still see it's wired). Format: https://.../{z}/{x}/{y}.png
NEXT_PUBLIC_MTN_TILES_URL=
