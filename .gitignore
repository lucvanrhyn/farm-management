# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Git worktrees
.worktrees/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# Production env (contains real Turso credentials — never commit)
.env.production

# vercel
.vercel

# Google OAuth credentials (NEVER commit these)
credentials.json
token.json

# Prisma database (local SQLite — never commit)
prisma/dev.db
prisma/dev.db-journal
prisma/prisma/dev.db
prisma/prisma/dev.db-journal

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright-cli snapshots & temp files
.playwright-cli/
.tmp/

# stray screenshots
*.png
*.jpg

# Playwright CLI snapshot artifacts (transient, per-run)
*.yaml.log
login*.yaml
relog.yaml
fresh.yaml
tmp/

# Bench snapshots (LHCI output). Keep `latest.json` in source control
# so we can diff it between PRs; ignore every timestamped run to avoid
# flooding git with noise. `scripts/bench-snapshot.ts` writes both.
tasks/bench/*.json
!tasks/bench/latest.json
