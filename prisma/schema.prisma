generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String            @id @default(cuid())
  email      String            @unique
  password   String
  name       String?
  role       String            @default("viewer")
  createdAt  DateTime          @default(now())
  alertPrefs AlertPreference[]
}

model Observation {
  id            String    @id @default(cuid())
  type          String
  campId        String
  animalId      String?
  details       String
  observedAt    DateTime
  createdAt     DateTime  @default(now())
  loggedBy      String?
  editedBy      String?
  editedAt      DateTime?
  editHistory   String?
  attachmentUrl String?

  @@index([type, campId, observedAt], name: "idx_obs_type_camp_date")
  @@index([type, animalId, observedAt], name: "idx_obs_type_animal_date")
}

model Animal {
  id                 String   @id @default(cuid())
  animalId           String   @unique
  name               String?
  sex                String
  dateOfBirth        String?
  breed              String   @default("Brangus")
  category           String
  currentCamp        String
  status             String   @default("Active")
  motherId           String?
  fatherId           String?
  mobId              String?
  registrationNumber String?
  dateAdded          String
  deceasedAt         String?
  createdAt          DateTime @default(now())
  // Multi-species support
  species            String   @default("cattle")
  speciesData        String?

  sireNote      String?
  damNote       String?
  importJobId   String?
  importJob     ImportJob? @relation(fields: [importJobId], references: [id], onDelete: SetNull)

  @@index([currentCamp, status], name: "idx_animal_camp_status")
  @@index([status], name: "idx_animal_status")
  @@index([species, status], name: "idx_animal_species_status")
  @@index([species, currentCamp, status], name: "idx_animal_species_camp_status")
}

model Transaction {
  id            String   @id @default(cuid())
  type          String
  category      String
  amount        Float
  date          String
  description   String
  animalId      String?
  campId        String?
  reference     String?
  createdBy     String?
  createdAt     DateTime @default(now())
  // Livestock purchase/sale fields
  saleType      String?  // "auction" | "private"
  counterparty  String?  // buyer or seller name
  quantity      Int?     // number of animals in batch
  avgMassKg     Float?   // average mass at transaction (kg)
  fees          Float?   // auction fees / commission
  transportCost Float?   // transport cost
  animalIds     String?  // JSON array of animal IDs for batch transactions

  @@index([date], name: "idx_transaction_date")
}

model TransactionCategory {
  id        String   @id @default(cuid())
  name      String
  type      String   // "income" | "expense"
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model FarmSettings {
  id                       String   @id @default("singleton")
  alertThresholdHours      Int      @default(48)
  farmName                 String   @default("My Farm")
  breed                    String   @default("Mixed")
  updatedAt                DateTime @updatedAt
  updatedBy                String?
  // Configurable thresholds
  adgPoorDoerThreshold     Float    @default(0.7)   // kg/day below which animal is a poor doer
  calvingAlertDays         Int      @default(14)    // days before expected calving to alert
  daysOpenLimit            Int      @default(365)   // max acceptable days open for a cow
  campGrazingWarningDays   Int      @default(7)     // days grazing remaining to trigger camp warning
  // Rotation planner defaults
  defaultRestDays          Int      @default(60)    // target rest period between grazings (days)
  defaultMaxGrazingDays    Int      @default(7)     // max days a mob stays in a camp before overstay alert
  rotationSeasonMode       String   @default("auto") // "auto" | "growing" | "dormant"
  dormantSeasonMultiplier  Float    @default(1.4)    // rest-days multiplier during dormant season
  // Location and farm settings
  latitude                 Float?
  longitude                Float?
  targetStockingRate       Float?
  breedingSeasonStart      String?
  breedingSeasonEnd        String?
  weaningDate              String?
  openaiApiKey             String?
  heroImageUrl             String?  @default("/farm-hero.jpg")
  // NVD seller identity fields
  ownerName                String?
  ownerIdNumber            String?  // SA ID number (optional, farmer discretion)
  physicalAddress          String?
  postalAddress            String?
  contactPhone             String?
  contactEmail             String?
  propertyRegNumber        String?  // SA property registration / LPHS number
  farmRegion               String?  // district / province
  biomeType                String?  // 'highveld' | 'bushveld' | 'lowveld' | 'karoo' | 'mixedveld'
  // Onboarding state
  onboardingComplete       Boolean  @default(false) // set true when wizard finishes OR tenant has substantial data (migration)
  // Notification preferences (Phase J)
  quietHoursStart          String?  @default("20:00")  // "HH:mm" local time; no non-critical push between start..end
  quietHoursEnd            String?  @default("06:00")
  timezone                 String?  @default("Africa/Johannesburg") // IANA tz for quiet-hour + digest scheduling
  speciesAlertThresholds   String?                     // JSON: per-species override blob, e.g. { cattle: { daysOpenLimit: 110 }, sheep: { ... } }
}

model NvdRecord {
  id                 String    @id @default(cuid())
  nvdNumber          String    @unique  // farm-scoped running number, format: "NVD-2026-0001"
  issuedAt           DateTime  @default(now())
  saleDate           String    // YYYY-MM-DD (match Transaction.date convention)
  transactionId      String?   // links to Transaction if user created sale from NVD flow
  buyerName          String
  buyerAddress       String?
  buyerContact       String?
  destinationAddress String?
  animalIds          String    // JSON array of animalId strings (snapshot)
  animalSnapshot     String    // JSON array of {animalId, category, sex, breed, dateOfBirth, lastCampId, lastMovementDate}
  sellerSnapshot     String    // JSON of FarmSettings seller fields at time of issue
  declarationsJson   String    // JSON of 7 NVD declaration booleans + notes
  generatedBy        String?   // user email
  pdfHash            String?   // sha256 of generated PDF for tamper-evident audit
  voidedAt           DateTime?
  voidReason         String?

  @@index([issuedAt], name: "idx_nvd_issued_at")
  @@index([transactionId], name: "idx_nvd_transaction")
}

model Camp {
  id                     String   @id @default(cuid())
  campId                 String   @unique
  campName               String
  sizeHectares           Float?
  waterSource            String?
  geojson                String?
  color                  String?
  createdAt              DateTime @default(now())
  // Rotation planner (all optional — fall back to FarmSettings defaults)
  veldType               String?  // 'sweetveld' | 'sourveld' | 'mixedveld' | 'cultivated'
  restDaysOverride       Int?
  maxGrazingDaysOverride Int?
  rotationNotes          String?
}

model CampCoverReading {
  id           String   @id @default(cuid())
  campId       String
  coverCategory String  // "Good" | "Fair" | "Poor"
  kgDmPerHa    Float    // derived from category or manually set
  useFactor    Float    @default(0.35)
  recordedAt   String
  recordedBy   String

  @@index([campId, recordedAt], name: "idx_cover_camp_date")
}

model Mob {
  id          String   @id @default(cuid())
  name        String
  currentCamp String
  createdAt   DateTime @default(now())

  @@index([currentCamp], name: "idx_mob_camp")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  campId      String?
  animalId    String?
  assignedTo  String
  createdBy   String
  dueDate     String
  status      String   @default("pending")
  priority    String   @default("normal")
  completedAt String?
  createdAt   DateTime @default(now())

  @@index([assignedTo, status, dueDate], name: "idx_task_assignee_status_date")
  @@index([dueDate, status], name: "idx_task_date_status")
}

// ── Multi-Species Settings ──────────────────────────────────────────────────

model FarmSpeciesSettings {
  id                    String   @id @default(cuid())
  species               String   @unique
  enabled               Boolean  @default(true)
  gestationDays         Int?
  voluntaryWaitingDays  Int?
  breedingSeasonStart   String?
  breedingSeasonEnd     String?
  weaningAgeDays        Int?
  targetStockingRate    Float?
  customLsuValues       String?
  customCategories      String?
  quotaConfig           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ── Game Module Tables ──────────────────────────────────────────────────────

model GameSpecies {
  id                     String   @id @default(cuid())
  commonName             String   @unique
  scientificName         String?
  dietaryClass           String
  lsuEquivalent          Float
  averageMassKg          Float?
  isTops                 Boolean  @default(false)
  defaultMortalityRate   Float    @default(0.05)
  defaultRecruitmentRate Float    @default(0.30)
  gestationDays          Int?
  trophyMinRW            Float?
  trophyMinSCI           Float?
  targetPopulation       Int?
  currentEstimate        Int      @default(0)
  lastCensusDate         String?
  createdAt              DateTime @default(now())
}

model GameCensusEvent {
  id              String   @id @default(cuid())
  date            String
  method          String
  observer        String
  conditions      String?
  confidenceLevel String   @default("moderate")
  marginOfError   Float?
  costRands       Float?
  notes           String?
  areaHectares    Float?
  createdAt       DateTime @default(now())

  @@index([date], name: "idx_game_census_date")
}

model GameCensusResult {
  id              String   @id @default(cuid())
  censusEventId   String
  speciesId       String
  totalCount      Int
  maleCount       Int?
  femaleCount     Int?
  juvenileCount   Int?
  campId          String?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([censusEventId], name: "idx_census_result_event")
  @@index([speciesId], name: "idx_census_result_species")
}

model GameHuntRecord {
  id                String   @id @default(cuid())
  huntType          String
  startDate         String
  endDate           String
  clientName        String
  clientNationality String?
  clientEmail       String?
  clientPhone       String?
  outfitterName     String?
  phName            String
  phLicenseNumber   String?
  dayFeePerDay      Float?
  totalDayFees      Float?
  totalTrophyFees   Float?
  totalRevenue      Float?
  notes             String?
  status            String   @default("active")
  createdAt         DateTime @default(now())

  @@index([startDate], name: "idx_hunt_start_date")
  @@index([huntType], name: "idx_hunt_type")
}

model GameHuntAnimal {
  id                   String   @id @default(cuid())
  huntRecordId         String
  speciesId            String
  sex                  String
  ageClass             String
  harvestDate          String
  campId               String?
  gpsLat               Float?
  gpsLon               Float?
  caliber              String?
  trophyMeasurementRW  Float?
  trophyMeasurementSCI Float?
  trophyNotes          String?
  trophyPhotoUrl       String?
  priceFeeRands        Float?
  bodyMassKg           Float?
  createdAt            DateTime @default(now())

  @@index([huntRecordId], name: "idx_hunt_animal_record")
  @@index([speciesId], name: "idx_hunt_animal_species")
  @@index([harvestDate], name: "idx_hunt_animal_date")
}

model GameOfftakeQuota {
  id          String   @id @default(cuid())
  speciesId   String
  season      String
  seasonStart String
  seasonEnd   String
  totalQuota  Int
  maleQuota   Int?
  femaleQuota Int?
  usedTotal   Int      @default(0)
  usedMale    Int      @default(0)
  usedFemale  Int      @default(0)
  quotaType   String
  notes       String?
  createdAt   DateTime @default(now())

  @@index([speciesId, season], name: "idx_quota_species_season")
}

model GameIntroduction {
  id              String   @id @default(cuid())
  speciesId       String
  date            String
  direction       String
  count           Int
  sex             String?
  sourceFarm      String?
  destinationFarm String?
  costRands       Float?
  revenueRands    Float?
  transportPermit String?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([speciesId, date], name: "idx_intro_species_date")
}

model GamePredationEvent {
  id                 String   @id @default(cuid())
  date               String
  predatorSpecies    String
  preySpeciesId      String?
  preyCount          Int      @default(1)
  preySex            String?
  campId             String?
  gpsLat             Float?
  gpsLon             Float?
  evidenceType       String
  estimatedLossRands Float?
  responseAction     String?
  notes              String?
  attachmentUrl      String?
  createdAt          DateTime @default(now())

  @@index([date], name: "idx_predation_date")
  @@index([predatorSpecies], name: "idx_predation_predator")
  @@index([campId], name: "idx_predation_camp")
}

model GameMortality {
  id                 String   @id @default(cuid())
  speciesId          String
  date               String
  count              Int      @default(1)
  cause              String
  sex                String?
  campId             String?
  estimatedLossRands Float?
  veterinaryReport   String?
  notes              String?
  createdAt          DateTime @default(now())

  @@index([speciesId, date], name: "idx_mortality_species_date")
  @@index([cause], name: "idx_mortality_cause")
}

model GameWaterPoint {
  id                  String   @id @default(cuid())
  name                String
  type                String
  campId              String?
  gpsLat              Float?
  gpsLon              Float?
  depthMeters         Float?
  yieldLitersPerHour  Float?
  capacityLiters      Float?
  pumpType            String?
  status              String   @default("operational")
  lastInspected       String?
  notes               String?
  createdAt           DateTime @default(now())

  @@index([campId], name: "idx_water_point_camp")
  @@index([status], name: "idx_water_point_status")
}

model GameInfrastructure {
  id                  String   @id @default(cuid())
  type                String
  name                String
  campId              String?
  gpsLat              Float?
  gpsLon              Float?
  lengthKm            Float?
  capacityAnimals     Int?
  condition           String   @default("good")
  lastMaintenanceDate String?
  nextMaintenanceDate String?
  maintenanceCostRands Float?
  notes               String?
  createdAt           DateTime @default(now())

  @@index([type], name: "idx_infra_type")
  @@index([condition], name: "idx_infra_condition")
}

model GamePermit {
  id               String   @id @default(cuid())
  type             String
  permitNumber     String?
  speciesId        String?
  issuedDate       String?
  expiryDate       String?
  issuingAuthority String?
  status           String   @default("active")
  quotaAllocated   Int?
  documentUrl      String?
  notes            String?
  createdAt        DateTime @default(now())

  @@index([type, status], name: "idx_permit_type_status")
  @@index([expiryDate], name: "idx_permit_expiry")
}

model GameVeldCondition {
  id                       String   @id @default(cuid())
  campId                   String
  date                     String
  assessor                 String
  method                   String   @default("grazing_index")
  grazingScore             Float?
  browseScore              Float?
  coverCategory            String?
  kgDmPerHa                Float?
  grassSpeciesComposition  String?
  bushEncroachment         String?
  erosionLevel             String?
  notes                    String?
  createdAt                DateTime @default(now())

  @@index([campId, date], name: "idx_veld_camp_date")
}

model VeldAssessment {
  id                      String   @id @default(cuid())
  campId                  String
  assessmentDate          String   // YYYY-MM-DD (match RainfallRecord / CampCoverReading convention)
  assessor                String
  // Raw farmer inputs (DFFE EIM)
  palatableSpeciesPct     Float    // 0..100
  bareGroundPct           Float    // 0..100
  erosionLevel            Int      // 0=none, 1=moderate, 2=severe
  bushEncroachmentLevel   Int      // 0=sparse, 1=moderate, 2=dense
  // Computed at insert time (denormalised for fast reads, replayable from inputs)
  veldScore               Float    // 0..10 output of calcVeldScore
  biomeAtAssessment       String?  // snapshot of FarmSettings.biomeType at insert
  haPerLsu                Float?   // snapshot of calcGrazingCapacity().haPerLsu
  notes                   String?
  createdAt               DateTime @default(now())
  createdBy               String?  // user email

  @@index([campId, assessmentDate], name: "idx_veld_assessment_camp_date")
  @@index([assessmentDate], name: "idx_veld_assessment_date")
}

model RainfallRecord {
  id          String   @id @default(cuid())
  date        String
  rainfallMm  Float
  stationName String?
  campId      String?
  createdAt   DateTime @default(now())

  @@map("GameRainfallRecord")
  @@index([date], name: "idx_rainfall_date")
}

// ── Rainfall Climatology Cache ──────────────────────────────────────────────

model RainfallNormal {
  id          String   @id @default(cuid())
  latitude    Float
  longitude   Float
  monthIdx    Int      // 1..12 (calendar month)
  meanMm      Float    // long-term mean monthly rainfall (mm)
  stdDevMm    Float    // population stdDev (mm)
  sampleYears Int      // number of years used to compute the normal
  computedAt  DateTime @default(now())

  @@unique([latitude, longitude, monthIdx], name: "rain_norm_latlng_month")
  @@index([latitude, longitude], name: "idx_rain_norm_latlng")
}

// ── SARS / IT3 Tax Export Snapshot ──────────────────────────────────────────

model It3Snapshot {
  id           String    @id @default(cuid())
  taxYear      Int       // the calendar year the SA tax year ends in (e.g. 2026 → 2025-03-01..2026-02-28)
  issuedAt     DateTime  @default(now())
  periodStart  String    // YYYY-MM-DD
  periodEnd    String    // YYYY-MM-DD
  payload      String    // JSON: { schedules, totals, farmSnapshot, categoryMap, meta }
  generatedBy  String?   // user email at issue time
  pdfHash      String?   // sha256 of generated PDF for tamper-evident audit
  voidedAt     DateTime?
  voidReason   String?

  @@index([taxYear], name: "idx_it3_tax_year")
  @@index([issuedAt], name: "idx_it3_issued_at")
}

// ── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  type        String   // e.g. "calving_due_7d" | "calving_overdue" | "poor_doer" | "withdrawal_expiring" | "stale_inspection"
  severity    String   // "red" | "amber"
  message     String
  href        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  // Phase J — dedup + digest support
  dedupKey           String?   // stable key like "NO_WEIGHING_90D:camp-7:2026-W16" — merge+bump on collision
  payload            String?   // JSON: { animalIds?, campId?, count?, speciesId?, ...renderer inputs }
  collapseKey        String?   // grouping unit: campId, speciesId, tenantId — used by digest algorithm
  updatedAt          DateTime  @updatedAt
  // Phase J — dispatch idempotency (at-most-once delivery under Inngest retry)
  pushDispatchedAt   DateTime? // set BEFORE push send; retries skip if non-null
  digestDispatchedAt DateTime? // set BEFORE digest send; retries skip if non-null

  @@unique([type, dedupKey], name: "unique_type_dedup")
  @@index([isRead, createdAt], name: "idx_notification_read_date")
  @@index([collapseKey])
}

// ── Alert Preferences (Phase J) ─────────────────────────────────────────────

model AlertPreference {
  id              String   @id @default(cuid())
  userId          String
  category        String   // "reproduction" | "performance" | "veld" | "finance" | "compliance" | "weather" | "predator"
  alertType       String?  // null = whole-category pref; specific type like "lambing_due_7d" for per-alert override
  channel         String   // "bell" | "email" | "push" | "whatsapp"
  enabled         Boolean  @default(true)
  digestMode      String   @default("realtime") // "realtime" | "daily" | "weekly"
  speciesOverride String?  // null = all species; "cattle" | "sheep" | "game" to scope
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, alertType, channel, speciesOverride], name: "unique_user_pref")
  @@index([userId])
}

// ── Push Subscriptions ──────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userEmail String
  createdAt DateTime @default(now())

  @@index([userEmail], name: "idx_push_user")
}

// ── Rotation Plans ───────────────────────────────────────────────────────────

model RotationPlan {
  id        String             @id @default(cuid())
  name      String
  startDate DateTime
  status    String             @default("draft")  // draft|active|completed|archived
  notes     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  steps     RotationPlanStep[]
}

model RotationPlanStep {
  id                    String       @id @default(cuid())
  planId                String
  sequence              Int
  campId                String
  mobId                 String?
  plannedStart          DateTime
  plannedDays           Int
  status                String       @default("pending")  // pending|executed|skipped
  actualStart           DateTime?
  actualEnd             DateTime?
  executedObservationId String?
  notes                 String?
  plan                  RotationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, sequence], name: "plan_sequence")
  @@index([planId, sequence], name: "idx_plan_step_plan_seq")
}

// ── Budgets ─────────────────────────────────────────────────────────────────

model Budget {
  id           String   @id @default(cuid())
  year         Int
  month        Int
  categoryName String
  type         String
  amount       Float
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([year, month, categoryName], name: "budget_year_month_category")
  @@index([year, month], name: "idx_budget_period")
}

model ImportJob {
  id             String    @id @default(cuid())
  farmId         String
  sourceFileHash String
  sourceFilename String
  mappingJson    String
  rowsImported   Int       @default(0)
  rowsFailed     Int       @default(0)
  warnings       String?
  inputTokens    Int?
  outputTokens   Int?
  cachedTokens   Int?
  costZar        Float?
  createdAt      DateTime  @default(now())
  confirmedBy    String
  status         String?   // "pending" | "running" | "complete" | "failed"
  completedAt    DateTime?
  animals        Animal[]

  @@index([farmId, createdAt])
}

model CustomField {
  id        String   @id @default(cuid())
  farmId    String
  name      String
  appliesTo String
  dataType  String
  source    String
  createdAt DateTime @default(now())

  @@unique([farmId, appliesTo, name])
}
