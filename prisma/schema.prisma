generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("viewer")
  createdAt DateTime @default(now())
}

model Observation {
  id         String   @id @default(cuid())
  type       String
  campId     String
  animalId   String?
  details    String
  observedAt DateTime
  createdAt  DateTime @default(now())
}
