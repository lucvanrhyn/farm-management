generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("viewer")
  createdAt DateTime @default(now())
}

model Observation {
  id            String    @id @default(cuid())
  type          String
  campId        String
  animalId      String?
  details       String
  observedAt    DateTime
  createdAt     DateTime  @default(now())
  loggedBy      String?
  editedBy      String?
  editedAt      DateTime?
  editHistory   String?
  attachmentUrl String?
}

model Animal {
  id          String   @id @default(cuid())
  animalId    String   @unique
  name        String?
  sex         String
  dateOfBirth String?
  breed       String   @default("Brangus")
  category    String
  currentCamp String
  status      String   @default("Active")
  motherId    String?
  fatherId    String?
  notes       String?
  dateAdded   String
  createdAt   DateTime @default(now())
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  category    String
  amount      Float
  date        String
  description String
  animalId    String?
  campId      String?
  reference   String?
  createdBy   String?
  createdAt   DateTime @default(now())
}

model TransactionCategory {
  id        String   @id @default(cuid())
  name      String
  type      String   // "income" | "expense"
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model FarmSettings {
  id                  String   @id @default("singleton")
  alertThresholdHours Int      @default(48)
  updatedAt           DateTime @updatedAt
  updatedBy           String?
}
