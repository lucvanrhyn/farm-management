# `lib/farm-schema.ts` is generated by `pnpm db:gen-schema` from the LF output
# of `prisma migrate diff`. Pin it to LF so `pnpm db:gen-schema:check` (a
# byte-for-byte comparison) doesn't false-fail for contributors on Windows
# whose git would otherwise check it out with CRLF line endings.
lib/farm-schema.ts text eol=lf
